---
// Stockbrowse Landing Page - Public coming soon page
const title = "Stockbrowse - Coming Spring 2026";
const description = "Browse stocks like products. Invest with clarity. Every stock rated 0-100.";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />

  <title>{title}</title>

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;600;700;800&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg-primary: #080A0F;
      --bg-surface: #161B24;
      --bg-elevated: #1C222E;
      --text-primary: #F1F5F9;
      --text-secondary: #CBD5E1;
      --text-muted: #64748B;
      --accent-cyan: #22D3EE;
      --accent-cyan-dark: #06B6D4;
      --border: rgba(255, 255, 255, 0.06);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* Header */
    .header {
      padding: 1.5rem 0;
      border-bottom: 1px solid var(--border);
      background: rgba(12, 15, 20, 0.8);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .logo-icon {
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 0.5rem;
      background: linear-gradient(135deg, var(--accent-cyan), var(--accent-cyan-dark));
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--bg-primary);
      font-weight: 900;
      font-size: 1.125rem;
    }

    .logo-text {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.5px;
    }

    .logo-text .brand {
      color: var(--text-primary);
    }

    .logo-text .accent {
      color: var(--accent-cyan);
    }

    /* Hero */
    .hero {
      padding: 6rem 0 4rem;
      text-align: center;
    }

    .badge {
      display: inline-block;
      padding: 0.5rem 1rem;
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 9999px;
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--accent-cyan);
      margin-bottom: 2rem;
      animation: fadeUp 0.6s ease-out;
    }

    h1 {
      font-size: 3.5rem;
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 1.5rem;
      animation: fadeUp 0.6s ease-out 0.1s both;
    }

    h1 .gradient {
      background: linear-gradient(135deg, var(--accent-cyan), var(--accent-cyan-dark));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .subtitle {
      font-size: 1.25rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto 3rem;
      animation: fadeUp 0.6s ease-out 0.2s both;
    }

    /* Waitlist Section */
    .waitlist-section {
      padding: 6rem 0;
      background: var(--bg-surface);
    }

    .waitlist-box {
      max-width: 600px;
      margin: 0 auto;
      text-align: center;
    }

    .waitlist-form {
      max-width: 500px;
      margin: 0 auto 1rem;
      display: flex;
      gap: 0.75rem;
    }

    .waitlist-form input {
      flex: 1;
      padding: 1rem 1.25rem;
      background: var(--bg-primary);
      border: 1px solid var(--border);
      border-radius: 0.75rem;
      color: var(--text-primary);
      font-size: 1rem;
      font-family: inherit;
      transition: all 0.2s;
    }

    .waitlist-form input:focus {
      outline: none;
      border-color: var(--accent-cyan);
      box-shadow: 0 0 0 3px rgba(34, 211, 238, 0.1);
    }

    .waitlist-form input::placeholder {
      color: var(--text-muted);
    }

    .waitlist-form button {
      padding: 1rem 2rem;
      background: var(--accent-cyan);
      color: var(--bg-primary);
      border: none;
      border-radius: 0.75rem;
      font-size: 1rem;
      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
    }

    .waitlist-form button:hover {
      background: var(--accent-cyan-dark);
      transform: translateY(-1px);
    }

    .waitlist-note {
      text-align: center;
      font-size: 0.875rem;
      color: var(--text-muted);
    }

    /* Features Section */
    .features {
      padding: 6rem 0;
    }

    .section-title {
      text-align: center;
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 1rem;
    }

    .section-subtitle {
      text-align: center;
      font-size: 1.125rem;
      color: var(--text-secondary);
      max-width: 700px;
      margin: 0 auto 4rem;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
    }

    .feature-card {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 1rem;
      padding: 2rem;
      transition: all 0.3s;
    }

    .feature-card:hover {
      border-color: var(--accent-cyan);
      transform: translateY(-4px);
    }

    .feature-icon {
      width: 3rem;
      height: 3rem;
      background: rgba(34, 211, 238, 0.1);
      border-radius: 0.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .feature-card h3 {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
    }

    .feature-card p {
      color: var(--text-secondary);
      line-height: 1.7;
    }

    /* Timeline */
    .timeline {
      padding: 6rem 0;
    }

    .timeline-items {
      max-width: 600px;
      margin: 0 auto;
    }

    .timeline-item {
      display: flex;
      gap: 1.5rem;
      margin-bottom: 2.5rem;
      position: relative;
    }

    .timeline-item:not(:last-child)::before {
      content: '';
      position: absolute;
      left: 1rem;
      top: 2.5rem;
      bottom: -2.5rem;
      width: 2px;
      background: var(--border);
    }

    .timeline-icon {
      width: 2rem;
      height: 2rem;
      background: var(--accent-cyan);
      border-radius: 50%;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.875rem;
    }

    .timeline-icon.pending {
      background: var(--bg-surface);
      border: 2px solid var(--border);
    }

    .timeline-content h3 {
      font-size: 1.125rem;
      margin-bottom: 0.5rem;
    }

    .timeline-content p {
      color: var(--text-secondary);
    }

    /* Footer */
    .footer {
      border-top: 1px solid var(--border);
      padding: 3rem 0;
      text-align: center;
    }

    .footer-content {
      max-width: 600px;
      margin: 0 auto;
    }

    .footer-logo {
      margin-bottom: 1rem;
    }

    .footer p {
      color: var(--text-muted);
      font-size: 0.875rem;
      margin-bottom: 2rem;
    }

    .powered-by {
      display: inline-block;
      padding: 0.75rem 1.5rem;
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .powered-by strong {
      color: var(--accent-cyan);
    }

    /* Animations */
    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Responsive */
    @media (max-width: 768px) {
      h1 {
        font-size: 2.5rem;
      }

      .subtitle {
        font-size: 1.125rem;
      }

      .waitlist-form {
        flex-direction: column;
      }

      .features-grid {
        grid-template-columns: 1fr;
      }

      .score-table {
        overflow-x: auto;
      }
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="container">
      <div class="logo">
        <div class="logo-icon">S</div>
        <div class="logo-text">
          <span class="brand">Stock</span><span class="accent">browse</span>
        </div>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="badge">Coming Spring 2026</div>
      <h1>
        Browse Stocks Like <span class="gradient">Products</span>
      </h1>
      <p class="subtitle">
        Every stock rated 0-100 based on 30 years of research. No spreadsheets, no jargon.
        Just quality scores you can trust.
      </p>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <div class="container">
      <h2 class="section-title">What is Stockbrowse?</h2>
      <p class="section-subtitle">
        We're building the easiest way to research stocks. Think Amazon product reviews,
        but for investing.
      </p>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🔍</div>
          <h3>Browse by Your Goals</h3>
          <p>
            Filter stocks by industry, budget, dividends, or risk level.
            No finance degree required.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>See the Compass Score</h3>
          <p>
            Every stock rated 0-100 based on profitability, cash flow, and stability.
            Backed by 30 years of data.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">✅</div>
          <h3>Read Plain English</h3>
          <p>
            No spreadsheets. Get a simple assessment: is this a quality company?
            Make better decisions faster.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Waitlist Signup -->
  <section class="waitlist-section">
    <div class="container">
      <div class="waitlist-box">
        <h2 class="section-title">Join the Waitlist</h2>
        <p class="section-subtitle">
          Be the first to know when Stockbrowse launches. Get early access and exclusive updates.
        </p>

        <form class="waitlist-form" id="waitlistForm">
          <input
            type="email"
            name="email"
            placeholder="Enter your email"
            required
          />
          <button type="submit">Join Waitlist</button>
        </form>
        <p class="waitlist-note">No spam, ever. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="timeline">
    <div class="container">
      <h2 class="section-title">Our Progress</h2>
      <p class="section-subtitle">
        Building in public. Here's where we are on the journey.
      </p>

      <div class="timeline-items">
        <div class="timeline-item">
          <div class="timeline-icon">✓</div>
          <div class="timeline-content">
            <h3>Compass Score Research</h3>
            <p>Developed and validated our quality scoring system using 30 years of historical data. Complete.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-icon pending"></div>
          <div class="timeline-content">
            <h3>Platform Development</h3>
            <p>Building the web platform to make stock research accessible to everyone. In progress.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-icon pending"></div>
          <div class="timeline-content">
            <h3>Private Beta</h3>
            <p>Testing with a small group to refine the experience. Coming soon.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-icon pending"></div>
          <div class="timeline-content">
            <h3>Public Launch</h3>
            <p>Opening Stockbrowse to everyone. Spring 2026.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-logo">
          <div class="logo">
            <div class="logo-icon">S</div>
            <div class="logo-text">
              <span class="brand">Stock</span><span class="accent">browse</span>
            </div>
          </div>
        </div>
        <p>Browse stocks like products. Invest with clarity.</p>
        <div class="powered-by">
          Powered by the <strong>Compass Score</strong>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // Waitlist form handler
    const form = document.getElementById('waitlistForm');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const email = formData.get('email');

        // Store locally (production: send to API)
        try {
          const waitlist = JSON.parse(localStorage.getItem('waitlist') || '[]');
          waitlist.push({ email, timestamp: new Date().toISOString() });
          localStorage.setItem('waitlist', JSON.stringify(waitlist));

          alert('Thanks! You\'re on the waitlist. We\'ll email you when we launch.');
          form.reset();
        } catch (error) {
          alert('Thanks for your interest! Please try again.');
        }
      });
    }
  </script>
</body>
</html>
